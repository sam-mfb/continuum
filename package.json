{
  "name": "continuum",
  "version": "1.3.1",
  "type": "module",
  "description": "Recreation of the 68000 Mac game Continuum for the web",
  "scripts": {
    "dev": "vite",
    "game": "VITE_APP_MODE=game vite",
    "build:dev": "tsc && vite build",
    "build:game": "tsc && VITE_APP_MODE=game vite build",
    "build": "npm run build:dev && npm run build:game",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit -p scripts/tsconfig.json",
    "export-sprites": "tsx scripts/export-sprites.ts",
    "convert-sprites": "tsx scripts/convert-white-to-transparent.ts",
    "convert-digits": "tsx scripts/convert-digit-sprites.ts",
    "fix-shipshot": "tsx scripts/fix-shipshot.ts",
    "validate-recording": "tsx scripts/validate-recording.ts"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "nipplejs": "^0.10.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitejs/plugin-react": "^4.5.0",
    "@vitest/ui": "^3.1.4",
    "canvas": "^3.2.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.7.4",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.6",
    "vite-node": "^3.1.4",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
